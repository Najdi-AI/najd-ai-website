# Contact form lead delivery (app/api/contact/route.ts)
# All optional: with none set, leads are logged server-side and the form still works.

# Resend API key. When set, leads are emailed via the Resend HTTP API.
# Leave unset in dev to fall back to console.log (no secrets required).
RESEND_API_KEY=

# Inbox that receives lead emails. Defaults to siteConfig.email if unset.
CONTACT_INBOX=

# Sender shown on lead emails. Must be a Resend-verified sender/domain.
# Defaults to "<site name> Website <onboarding@resend.dev>" if unset.
CONTACT_FROM=

# Supabase lead storage (app/api/contact/route.ts).
# When BOTH are set, every lead is inserted into the `contact_leads` table.
# Leave unset to skip DB storage (the form still works / still emails).
# SUPABASE_URL is your project URL, e.g. https://<ref>.supabase.co
# SUPABASE_ANON_KEY is the project's anon/publishable key (RLS allows insert only).
SUPABASE_URL=
SUPABASE_ANON_KEY=
